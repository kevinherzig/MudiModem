#!/bin/sh
# /usr/sbin/mudimodem-revert — MudiModem confirm-or-revert watchdog + panic restore.
#
# WHY this exists (CLAUDE.md §5): band lock persists in modem NV and a bad lock
# can drop the cellular link you are administering over. So every band write is
# confirm-or-revert. nginx runs 4 workers with no shared state, so a timer there
# is unreliable — instead set_bands launches THIS as a detached process.
#
# Modes:
#   watch              sleep the revert window, then restore the previous band
#                      config UNLESS mudimodem.confirm removed the pending file.
#   boot-check         run from init at boot; if a pending revert survived a
#                      reboot (file still present), restore now — the NV lock
#                      would otherwise outlive the (dead) watchdog.
#   panic [sub_id]     immediate restore to the known-good full band lists,
#                      clear cell locks, and reset save_ctrl + mode_pref to
#                      AUTO. ssh-callable when the web UI is down:
#                        ssh root@mudi /usr/sbin/mudimodem-revert panic
#
# Safety:
#   - State lives in /etc (survives reboot), never /tmp.
#   - Band writes hit NV immediately (no commit step), so revert = write the
#     previous list back.
#   - Env overrides for testing (the isolation tests set all three):
#       MUDIMODEM_DRY=1        log intended AT writes instead of running them
#       MUDIMODEM_WINDOW=<s>   revert window (default 60)
#       MUDIMODEM_PENDING=<f>  pending-state path (default /etc/mudimodem/pending)
#       MUDIMODEM_LOG=<f>      log path

set -u
PENDING="${MUDIMODEM_PENDING:-/etc/mudimodem/pending}"
ARMED="${MUDIMODEM_ARMED:-/etc/mudimodem/armed}"
LOG="${MUDIMODEM_LOG:-/var/log/mudimodem-revert.log}"
WINDOW="${MUDIMODEM_WINDOW:-60}"
DRY="${MUDIMODEM_DRY:-0}"
HIST_DIR="${MUDIMODEM_HIST:-/tmp/mudimodem}"
STALE="${MUDIMODEM_STALE:-/etc/mudimodem/gl-stale}"

# Append a "dog" event to the Tracking telemetry log when we auto-revert, so the
# timeline shows the watchdog firing even with no browser open (spec §4.1).
append_event() {  # $1=kind $2=label $3=detail
  mkdir -p "$HIST_DIR" 2>/dev/null
  ts=$(( $(date +%s) * 1000 ))
  printf '{"t":%s,"kind":"%s","label":"%s","detail":"%s"}\n' "$ts" "$1" "$2" "$3" \
    >> "$HIST_DIR/events.jsonl" 2>/dev/null
}

# Known-good = the full module-supported SA set (CLAUDE.md §5). Not a curated
# safe subset — simply everything the module supports.
KG_SA="2:5:7:12:13:14:25:26:29:30:38:41:48:66:70:71:77:78"

log() { echo "$(date '+%F %T') [$$] $*" >> "$LOG" 2>/dev/null; }

# Run one AT command. Inner quotes are JSON-escaped (CLAUDE.md §8), else ubus
# silently returns empty/ERROR.
at() {  # $1 = AT command, $2 = sub_id
  esc=$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')
  json=$(printf '{"cmd":"%s","timeout":10,"sub_id":%s}' "$esc" "$2")
  if [ "$DRY" = "1" ]; then
    log "DRY at: $json"
    return 0
  fi
  ubus call modem.CPU.AT get_result_AT "$json" >> "$LOG" 2>&1
}

set_band() {  # $1 = param (e.g. nr5g_band), $2 = colon list, $3 = sub_id
  [ -n "$2" ] || return 0
  log "restore $1 -> $2 (sub_id $3)"
  at "AT+QNWPREFCFG=\"$1\",$2" "$3"
}

restore_from_pending() {
  if [ ! -f "$PENDING" ]; then log "no pending file; nothing to restore"; return 0; fi
  KIND=""; SUB_ID=1; RAT=""; PREV_SAVE_CTRL=""; PREV_mode_pref=""; PREV_nr5g_disable_mode=""
  PREV_nr5g_band=""; PREV_nsa_nr5g_band=""; PREV_lte_band=""
  # shellcheck disable=SC1090
  . "$PENDING"
  if [ "$KIND" = "cell" ]; then
    # Cell lock: raw-AT unlock saves the LINK now; GL's store is reconciled by
    # the backend once the page can reach it again (the stale marker drives that).
    log "cell revert: unlock common/${RAT:-5g} (sub_id ${SUB_ID:-1})"
    at "AT+QNWLOCK=\"common/${RAT:-5g}\",0" "${SUB_ID:-1}"
    [ -n "$PREV_SAVE_CTRL" ]        && at "AT+QNWLOCK=\"save_ctrl\",$PREV_SAVE_CTRL" "${SUB_ID:-1}"
    [ -n "$PREV_mode_pref" ]        && at "AT+QNWPREFCFG=\"mode_pref\",$PREV_mode_pref" "${SUB_ID:-1}"
    [ -n "$PREV_nr5g_disable_mode" ] && at "AT+QNWPREFCFG=\"nr5g_disable_mode\",$PREV_nr5g_disable_mode" "${SUB_ID:-1}"
    : > "$STALE" 2>/dev/null
  else
    [ -n "${PREV_nr5g_band:-}" ]     && set_band "nr5g_band"     "$PREV_nr5g_band"     "${SUB_ID:-1}"
    [ -n "${PREV_nsa_nr5g_band:-}" ] && set_band "nsa_nr5g_band" "$PREV_nsa_nr5g_band" "${SUB_ID:-1}"
    [ -n "${PREV_lte_band:-}" ]      && set_band "lte_band"      "$PREV_lte_band"      "${SUB_ID:-1}"
    [ -n "${PREV_mode_pref:-}" ]     && { log "restore mode_pref -> $PREV_mode_pref"; at "AT+QNWPREFCFG=\"mode_pref\",$PREV_mode_pref" "${SUB_ID:-1}"; }
  fi
  rm -f "$PENDING"
  log "revert complete; pending cleared"
}

case "${1:-}" in
  watch)
    # Ownership nonce (Finding I1): stamp the arm marker with THIS process's
    # pid and act only while the marker still holds it. Without this, a prior
    # watchdog that is still sleeping when a NEW experiment starts would wake,
    # see the new PENDING, and revert it prematurely. A new experiment does
    # `os.remove(ARMED)` then launches a new watchdog which stamps its own
    # nonce, so the old watchdog's nonce no longer matches and it stands down.
    # Drop the marker BEFORE sleeping so set_bands/set_cell_lock can confirm
    # the safety net is live before writing the (potentially link-dropping) change.
    MYNONCE=$$
    echo "$MYNONCE" > "$ARMED" 2>/dev/null
    log "watch armed (nonce $MYNONCE); window ${WINDOW}s; pending=$PENDING"
    sleep "$WINDOW"
    if [ ! -f "$PENDING" ]; then
      log "confirmed within window; no revert"
    elif [ "$(cat "$ARMED" 2>/dev/null)" != "$MYNONCE" ]; then
      log "superseded by a newer watchdog (arm no longer ours); no revert"
    else
      log "window elapsed, still pending and arm is ours -> reverting"
      restore_from_pending
      append_event "dog" "Auto-revert fired" "No confirm in ${WINDOW}s — previous config restored"
    fi
    # Clear the marker only if it is still ours (don't stomp a newer watchdog).
    [ "$(cat "$ARMED" 2>/dev/null)" = "$MYNONCE" ] && rm -f "$ARMED"
    ;;
  boot-check)
    if [ -f "$PENDING" ]; then
      log "boot-check: stale pending found -> reverting"
      restore_from_pending
    else
      log "boot-check: nothing pending"
    fi
    ;;
  panic)
    SUB="${2:-1}"
    log "PANIC restore -> known-good SA (sub_id $SUB)"
    set_band "nr5g_band" "$KG_SA" "$SUB"
    # Clear cell locks and reset the prefs a lock can leave behind, so panic
    # returns the modem to a fully open, auto-selecting state.
    at 'AT+QNWLOCK="common/4g",0' "$SUB"
    at 'AT+QNWLOCK="common/5g",0' "$SUB"
    at 'AT+QNWLOCK="save_ctrl",0,0' "$SUB"
    at 'AT+QNWPREFCFG="mode_pref",AUTO' "$SUB"
    # A 4G lock forces nr5g_disable_mode=1; clear it (Finding M1) so panic
    # actually returns to a fully open, NR5G-capable state rather than 4G-only.
    at 'AT+QNWPREFCFG="nr5g_disable_mode",0' "$SUB"
    rm -f "$PENDING"
    log "panic complete"
    ;;
  *)
    echo "usage: $0 {watch|boot-check|panic [sub_id]}" >&2
    exit 1
    ;;
esac
