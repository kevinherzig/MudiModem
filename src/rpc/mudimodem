-- MudiModem RPC backend.  Loaded by oui.rpc via dofile(); returns a table of
-- functions.  ubus.call() here may use DOTTED object names (server-side, past
-- the /rpc dot gate), which is the whole reason this backend exists.
--
-- Reads: get_bands (three-layer model). Writes: set_bands (SA allowlist) +
-- confirm, both behind the /usr/sbin/mudimodem-revert confirm-or-revert
-- watchdog. set_bands refuses to write unless the watchdog has ARMED first.
--
-- ACL: admin session is aclgroup "root" => always allowed (oui/rpc.lua:87). No
-- ACL file needed; do NOT expose any no-auth method.

local ubus  = require "oui.ubus"
local cjson = require "cjson"

local M = {}

-- Paths (overridable via env for the isolation tests).
local PENDING    = os.getenv("MUDIMODEM_PENDING") or "/etc/mudimodem/pending"
local ARMED      = os.getenv("MUDIMODEM_ARMED")   or "/etc/mudimodem/armed"
local REVERT_BIN = os.getenv("MUDIMODEM_BIN")     or "/usr/sbin/mudimodem-revert"
local STALE      = os.getenv("MUDIMODEM_STALE")   or "/etc/mudimodem/gl-stale"
-- History telemetry lives in tmpfs (volatile), separate from the durable /etc
-- pending state. samples.jsonl is written by mudimodem-collectd; events.jsonl by
-- us (user events) + the watchdog (dog events). get_history serves both.
local HIST_DIR   = os.getenv("MUDIMODEM_HIST") or "/tmp/mudimodem"
local SAMPLES    = HIST_DIR .. "/samples.jsonl"
local EVENTS     = HIST_DIR .. "/events.jsonl"

-- An empty Lua table encodes as {} (object); GL's set_feature_config wants []
-- for empty band lists. cjson.empty_array is the sentinel that encodes as [].
local function arr(t)
  if type(t) == "table" and #t > 0 then return t end
  return cjson.empty_array
end

-- Editable RATs: our key <-> the AT param <-> GL's band_list key.
local RATS = {
  { key = "sa",  param = "nr5g_band",     gl = "NR-SA" },
  { key = "nsa", param = "nsa_nr5g_band", gl = "NR-NSA" },
  { key = "lte", param = "lte_band",      gl = "LTE" },
}
-- Network mode: our label <-> mode_pref (AT) == network_mode (GL config) value.
-- Only these three are exposed (GL's own choices). NSA needs an LTE anchor, so
-- it is usable only under AUTO; SA under AUTO/NR5G; LTE under AUTO/LTE.
local MODES = { AUTO = true, NR5G = true, LTE = true }

-- Call a dotted ubus object, returning (table|nil, err).
--
-- ⚠️ MUST NOT be wrapped in pcall: oui.ubus.call uses an nginx cosocket, which
-- YIELDS while waiting on I/O. This box's Lua cannot yield across a C-call
-- boundary (pcall), so a pcall wrapper makes every call throw
-- "attempt to yield across metamethod/C-call boundary". GL's own plugins call
-- ubus.call bare for exactly this reason. ubus.call already returns (nil, err)
-- on ubus-level failure without throwing, so no pcall is needed.
local function ucall(object, method, args)
  return ubus.call(object, method, args or {})
end

-- Run a raw AT command at a given sub_id, return the payload string (or nil).
local function at(cmd, sub_id)
  local res = ucall("modem.CPU.AT", "get_result_AT",
                    { cmd = cmd, timeout = 8, sub_id = sub_id })
  if not res or not res.data then return nil end
  return res.data
end

-- Parse a colon list "2:5:71" -> { 2, 5, 71 } (numbers, order preserved).
-- Band 0 does not exist in any RAT; the modem uses a lone "0" to mean EMPTY
-- (e.g. nsa_nr5g_band,0 when SA-only). So drop zeros -> {} means "none".
local function parse_list(s)
  local out = {}
  if not s then return out end
  for n in s:gmatch("(%d+)") do
    local v = tonumber(n)
    if v and v > 0 then out[#out + 1] = v end
  end
  return out
end

-- From a QNWPREFCFG multi-line blob, pull one key's list:
--   +QNWPREFCFG: "nr5g_band",25:41:48:66:71:77
local function pref_line(blob, key)
  if not blob then return nil end
  -- match  "<key>",<digits-with-colons>   (value may be empty)
  local val = blob:match('"' .. key .. '",([%d:]*)')
  return parse_list(val)
end

-- Same, but the raw value string, verbatim (for writing back on revert). "" if absent.
local function pref_raw(blob, key)
  if not blob then return "" end
  return blob:match('"' .. key .. '",([%d:]*)') or ""
end

local function file_exists(p)
  local f = io.open(p, "r")
  if f then f:close(); return true end
  return false
end

-- Read one key=value out of the pending file.
local function pending_get(key)
  if not file_exists(PENDING) then return nil end
  for line in io.lines(PENDING) do
    local k, v = line:match("^([%w_]+)=(.*)$")
    if k == key then return v end
  end
  return nil
end

-- Append one user/watchdog event to the shared telemetry log (spec §4.1). Net
-- (handover/failover) events are NOT written here — the page derives those from
-- the sample stream. A single O_APPEND JSON line < PIPE_BUF is atomic, so the
-- multiple appenders (us + the watchdog) don't corrupt each other.
local function append_event(kind, label, detail)
  os.execute("mkdir -p " .. HIST_DIR .. " 2>/dev/null")
  local f = io.open(EVENTS, "a")
  if not f then return end
  f:write(cjson.encode({ t = os.time() * 1000, kind = kind, label = label, detail = detail or "" }) .. "\n")
  f:close()
end

-- Extract the RPLMN (last quoted field) from a QSPN response:
--   +QSPN: "T-Mobile","T-Mobile","",0,"310260"
local function qspn_plmn(blob)
  if not blob then return nil end
  local last
  for q in blob:gmatch('"([^"]*)"') do last = q end   -- last quoted token
  return last                                          -- "310260" or nil
end

-- Resolve the sub_id that actually talks to the ACTIVE subscription.
-- sub_id=0 is unstable (CLAUDE.md §6), so we MATCH by PLMN rather than assume a
-- slot->sub_id mapping.  Returns (sub_id, operator_plmn, matched_bool).
local function resolve_sub_id(want_plmn)
  for _, sid in ipairs({ 1, 0, 2 }) do            -- prefer 1 (never lead with 0)
    local plmn = qspn_plmn(at("AT+QSPN", sid))
    if plmn and plmn ~= "" then
      if not want_plmn or plmn == want_plmn then
        return sid, plmn, (want_plmn ~= nil)
      end
    end
  end
  return 1, nil, false                            -- fallback: sub_id 1, flagged
end

-- Resolve the active subscription end-to-end: find the serving slot's PLMN from
-- ubus, then the sub_id whose QSPN matches it. Returns (sub_id, plmn, matched, slot).
local function resolve_active()
  local want_plmn
  local st = ucall("cellular.modem", "status", {})
  local slot = st and st.modems and st.modems[1] and st.modems[1].current_sim_slot
  local sims = ucall("cellular.sim", "info", {})
  if sims and sims.sims then
    for _, s in ipairs(sims.sims) do
      if tostring(s.slot) == tostring(slot) and s.mcc and s.mnc then
        want_plmn = tostring(s.mcc) .. tostring(s.mnc)
      end
    end
  end
  local sub_id, plmn, matched = resolve_sub_id(want_plmn)
  return sub_id, plmn, matched, slot
end

-- Call one of GL's C rpc plugins (modem.so) exactly as oui.rpc's glc_call does
-- (reference/oui-lib-rpc.lua:126): nginx-internal POST to /cgi-bin/glc, response
-- body is "<code> <json>". Returns (table|nil, err). NOT pcall-wrapped: capture
-- is a cosocket-style nginx API and must be allowed to yield.
local function glc(object, method, args)
  local res = ngx.location.capture("/cgi-bin/glc", {
    method = ngx.HTTP_POST,
    body = cjson.encode({ object = object, method = method, args = args or {} }),
  })
  if not res or res.status ~= 200 then
    return nil, "glc http " .. tostring(res and res.status)
  end
  local code = tonumber(res.body:match("(-?%d+)"))
  if code ~= 0 then return nil, code end                 -- GL error code (e.g. 20002044)
  local msg = res.body:match("%d+ (.*)") or ""
  local ok, obj = pcall(cjson.decode, msg)               -- decode can't yield; pcall fine
  if not ok or type(obj) ~= "table" then return nil, "glc bad json" end
  return obj
end

-- AT read with the crossed-reply guard (reference §10): the shared channel can
-- answer with a DIFFERENT command's payload. Retry until the reply carries the
-- expected marker; nil after 3 tries (callers treat nil as "unknown").
local function at_expect(cmd, expect, sub_id)
  for _ = 1, 3 do
    local blob = at(cmd, sub_id)
    if blob and blob:find(expect, 1, true) then return blob end
  end
  return nil
end

-- Numbers after a QNWLOCK tag:  '+QNWLOCK: "common/5g",516,127490,15,71'
local function qnwlock_nums(blob, tag)
  if not blob then return nil end
  local tail = blob:match('%+QNWLOCK: "' .. tag .. '",([%d,%s]*)')
  if not tail then return nil end
  local out = {}
  for n in tail:gmatch("(%d+)") do out[#out + 1] = tonumber(n) end
  return out
end

-- "common/4g": ,0 = unlocked; locked reply is ,<mode>,<freq>,<pci>
-- (field order per GL's own parser in /lib/functions/modem.sh:940-942).
local function parse_qnwlock4(blob)
  local n = qnwlock_nums(blob, "common/4g")
  if not n then return nil end
  if #n <= 1 then return { locked = (n[1] or 0) ~= 0 } end
  return { locked = true, mode = n[1], freq = n[2], pci = n[3] }
end

-- "common/5g": ,0 = unlocked; locked reply is ,<pci>,<freq>,<scs>,<band>
-- (PCI FIRST — reference §6a; parser order per modem.sh:926-929).
local function parse_qnwlock5(blob)
  local n = qnwlock_nums(blob, "common/5g")
  if not n then return nil end
  if #n <= 1 then return { locked = (n[1] or 0) ~= 0 } end
  return { locked = true, pci = n[1], freq = n[2], scs = n[3], band = n[4] }
end

local function parse_savectrl(blob)
  local n = qnwlock_nums(blob, "save_ctrl")
  if not n or #n < 2 then return nil end
  return { raw = n[1] .. "," .. n[2], s4g = n[1], s5g = n[2] }
end

-- Serving cell from QENG. SA field order verified on-box (reference §8):
-- "servingcell",<state>,"NR5G-SA",<duplex>,<mcc>,<mnc>,<cell_id>,<pci>,<tac>,<arfcn>,<band>,…
-- LTE order is from the 5-series manual (📘 — re-verify at the Task 7 milestone):
-- "servingcell",<state>,"LTE",<is_tdd>,<mcc>,<mnc>,<cell_id>,<pci>,<earfcn>,<band>,…
local function parse_serving(blob)
  if not blob then return nil end
  local line = blob:match('%+QENG: "servingcell"[^\r\n]*')
  if not line then return nil end
  local f = {}
  for tok in line:gmatch('[^,]+') do f[#f + 1] = (tok:gsub('^%s*"?', ''):gsub('"?%s*$', '')) end
  -- f[1]='+QENG: servingcell', f[2]=state, f[3]=rat
  local rat = f[3]
  if rat == "NR5G-SA" then
    return { rat = rat, cell_id = f[7], pci = tonumber(f[8]),
             arfcn = tonumber(f[10]), band = tonumber(f[11]) }
  elseif rat == "LTE" then
    return { rat = rat, cell_id = f[7], pci = tonumber(f[8]),
             arfcn = tonumber(f[9]), band = tonumber(f[10]) }
  end
  return { rat = rat }
end

-- READ: the three-layer band picture for the active subscription.
-- { supported={LTE,nsa,sa}, config={enable,mode,LTE,nsa,sa},
--   policy={LTE,nsa,sa}, capability={LTE,nsa,sa},
--   meta={bus,slot,plmn,sub_id,plmn_matched} }
function M.get_bands(args)
  local bus = (args and args.bus) or "cpu"

  -- 1. supported (module) — clean ubus, no AT.
  -- NB: info/status are called with {} (no bus). Passing bus changes what they
  -- return; get_feature_config below DOES want bus. (Verified on-box 2026-07-17.)
  local supported = { LTE = {}, nsa = {}, sa = {} }
  local info = ucall("cellular.modem", "info", {})
  local modem = info and info.modems and info.modems[1]
  if modem and modem.band then
    supported.LTE = modem.band.LTE or {}
    supported.nsa = modem.band["NR-NSA"] or {}
    supported.sa  = modem.band["NR-SA"] or {}
  end

  -- 2. active subscription (PLMN-matched sub_id), to target the AT queries.
  local sub_id, plmn, matched, slot = resolve_active()

  -- 3. config + mode — from GL's stored view (ONE ubus call, no AT).
  --    The AT channel is shared with GL's polling; too many raw-AT reads here
  --    make get_bands slow enough to trip the admin's request-timeout banner and
  --    congest GL's own polling. Reading get_feature_config instead drops FOUR
  --    AT round-trips. Safe now: Path B (confirm -> set_feature_config) keeps
  --    GL's stored config in sync with the modem on every Keep, so this is
  --    accurate whenever the user can edit — it lags only during a pending
  --    revert, when editing is locked. (This reverses the earlier "read raw AT"
  --    workaround, whose whole reason — GL not seeing our writes — Path B fixed.)
  local config = { enable = true, mode = 0, LTE = {}, nsa = {}, sa = {} }
  local feat = ucall("cellular.modem", "get_feature_config", { bus = bus })
  local fb = feat and feat.band and feat.band.band_list
  if fb then
    config.sa  = fb["NR-SA"] or {}
    config.nsa = fb["NR-NSA"] or {}
    config.LTE = fb.LTE or {}
  end
  local mode_pref = (feat and feat.network_mode) or nil   -- AUTO | NR5G | LTE

  -- 4. policy + capability — AT only, at the resolved sub_id.
  local pol_blob = at('AT+QNWPREFCFG="policy_band"', sub_id)
  local cap_blob = at('AT+QNWPREFCFG="ue_capability_band"', sub_id)
  local policy = {
    LTE = pref_line(pol_blob, "lte_band"),
    nsa = pref_line(pol_blob, "nsa_nr5g_band"),
    sa  = pref_line(pol_blob, "nr5g_band"),
  }
  local capability = {
    LTE = pref_line(cap_blob, "lte_band"),
    nsa = pref_line(cap_blob, "nsa_nr5g_band"),
    sa  = pref_line(cap_blob, "nr5g_band"),
  }

  return {
    supported = supported,
    config = config,
    policy = policy,
    capability = capability,
    meta = {
      bus = bus,
      slot = slot,
      plmn = plmn,
      sub_id = sub_id,
      plmn_matched = matched,   -- false => sub_id resolution is a best guess
      mode = mode_pref,         -- AUTO | NR5G | LTE (or a combo) — the RAT gate
    },
  }
end

-- READ: cell-lock picture — modem truth (QNWLOCK), GL's store (get_cell_tower),
-- the serving cell (lock target for pin-current), and stale/pending flags.
function M.get_lock(args)
  local sub_id, plmn, matched, slot = resolve_active()
  local l4 = parse_qnwlock4(at_expect('AT+QNWLOCK="common/4g"', '"common/4g"', sub_id))
  local l5 = parse_qnwlock5(at_expect('AT+QNWLOCK="common/5g"', '"common/5g"', sub_id))
  local sc = parse_savectrl(at_expect('AT+QNWLOCK="save_ctrl"', '"save_ctrl"', sub_id))
  local serving = parse_serving(at_expect('AT+QENG="servingcell"', '"servingcell"', sub_id))

  local gl = glc("modem", "get_cell_tower", { bus = "cpu" })
  local tower = gl and gl["slot" .. tostring(slot)] or nil
  local gl_locked = (tower and tower.cellid and tower.cellid ~= "") and true or false
  local modem_locked = (l4 and l4.locked) or (l5 and l5.locked) or false

  -- Shape unknown until Task 7 captures it; returned raw for the UI to inspect.
  local opcfg = glc("modem", "get_operator_config", { bus = "cpu" })

  return {
    lock = { l4g = l4, l5g = l5, save_ctrl = sc },
    gl = { locked = gl_locked, tower = tower },
    serving = serving,
    stale = file_exists(STALE) or (gl_locked and not modem_locked),
    pending_kind = pending_get("KIND") or (file_exists(PENDING) and "bands" or nil),
    operator_config = opcfg,
    meta = { sub_id = sub_id, slot = slot, plmn = plmn, plmn_matched = matched },
  }
end

-- SCAN: GL's full network scan (AT+QSCAN under the hood). DISRUPTIVE — the
-- modem leaves the serving cell for up to ~10 minutes. The UI gates this
-- behind an explicit warning; never call it as part of a read.
function M.scan_cells(args)
  local _, _, _, slot = resolve_active()
  local res, err = glc("modem", "scan_cell_tower", { bus = "cpu", slot = tonumber(slot) or 1 })
  if not res then return { error = "scan failed: " .. tostring(err) } end
  append_event("user", "Cell scan", "")
  return { towers = arr(res.towers or {}), ts = os.time() * 1000 }
end

-- WRITE: lock to one cell via GL's stack, protected by confirm-or-revert.
-- args = { rat="4g"|"5g", pci, freq, scs?, band?, extra? } — extra is an
-- optional table of passthrough tower fields (cellid, carrier, mcc, mnc, …)
-- from a scan row, forwarded verbatim so GL stores what it scanned.
function M.set_cell_lock(args)
  local rat = args and args.rat
  if rat ~= "4g" and rat ~= "5g" then return { error = "rat must be '4g' or '5g'" } end
  local function int(v)
    local n = tonumber(v)
    if n and n >= 0 and n == math.floor(n) then return n end
  end
  local pci, freq = int(args.pci), int(args.freq)
  if not pci or not freq then return { error = "pci and freq are required integers" } end
  local scs, band = int(args.scs), int(args.band)
  if rat == "5g" and (not scs or not band) then
    return { error = "a 5g lock needs scs and band" }
  end
  if file_exists(PENDING) then
    return { error = "another change is pending; keep or revert it first" }
  end

  local sub_id, _, _, slot = resolve_active()

  -- One lock at a time (keeps the revert target = "unlocked", always). Fail
  -- CLOSED: at_expect returns nil when it exhausts its retries (crossed AT
  -- replies under heavy polling, reference §10), and parse_qnwlock4/5 pass
  -- that nil straight through. Treating "couldn't read" the same as
  -- "verified unlocked" would let a write proceed over an undetected real
  -- lock and capture a bogus PREV revert target — so an unreadable state is
  -- refused, distinct from a readable-and-unlocked one.
  local l4 = parse_qnwlock4(at_expect('AT+QNWLOCK="common/4g"', '"common/4g"', sub_id))
  local l5 = parse_qnwlock5(at_expect('AT+QNWLOCK="common/5g"', '"common/5g"', sub_id))
  if not l4 or not l5 then
    return { error = "could not read current lock state; try again" }
  end
  if l4.locked or l5.locked then
    return { error = "a cell lock is already set; unlock first" }
  end

  -- Snapshot the revert target: current save_ctrl + mode prefs (GL's lock
  -- changes mode_pref / nr5g_disable_mode as a side effect — spec §0).
  local sc = parse_savectrl(at_expect('AT+QNWLOCK="save_ctrl"', '"save_ctrl"', sub_id))
  local mblob = at('AT+QNWPREFCFG="mode_pref"', sub_id)
  local pmode = (mblob and mblob:match('"mode_pref",([%w:]+)')) or ""
  local dblob = at('AT+QNWPREFCFG="nr5g_disable_mode"', sub_id)
  local pdis = (dblob and dblob:match('"nr5g_disable_mode",(%d+)')) or ""

  os.execute("mkdir -p /etc/mudimodem 2>/dev/null")
  local f = io.open(PENDING, "w")
  if not f then return { error = "cannot write pending state" } end
  f:write(table.concat({
    "KIND=cell", "SUB_ID=" .. sub_id, "SLOT=" .. tostring(slot), "RAT=" .. rat,
    "PREV_SAVE_CTRL=" .. ((sc and sc.raw) or ""),
    "PREV_mode_pref=" .. pmode,
    "PREV_nr5g_disable_mode=" .. pdis,
  }, "\n") .. "\n")
  f:close()

  -- Arm the watchdog; no arm, no write (same interlock as set_bands).
  os.remove(ARMED)
  os.execute(REVERT_BIN .. " watch >/dev/null 2>&1 &")
  os.execute("sleep 1")
  if not file_exists(ARMED) then
    os.remove(PENDING)
    return { error = "revert watchdog failed to arm; no change written" }
  end

  -- Write through GL so its store and the modem agree (spec §3).
  local payload = { bus = "cpu", slot = tonumber(slot) or 1, lock = true,
                    network_type = (rat == "5g") and "NR5G" or "LTE",
                    pci = pci, freq = freq }
  if rat == "5g" then payload.scs = scs; payload.band = band
  elseif band then payload.band = band end
  if type(args.extra) == "table" then
    for k, v in pairs(args.extra) do
      if payload[k] == nil then payload[k] = v end
    end
  end
  local res, err = glc("modem", "set_cell_tower", payload)
  if not res then
    os.remove(PENDING)          -- nothing was written; stand the watchdog down
    return { error = "GL lock call failed: " .. tostring(err) }
  end

  append_event("user", "Cell lock applied",
    rat .. " pci " .. pci .. " freq " .. freq .. (band and (" band " .. band) or ""))
  return { ok = true, window = 60, sub_id = sub_id,
           applied = { rat = rat, pci = pci, freq = freq, scs = scs, band = band } }
end

-- Unlock (risk-reducing — no revert window). Also the stale-store reconciler.
function M.clear_cell_lock(args)
  local _, _, _, slot = resolve_active()
  local gl = glc("modem", "get_cell_tower", { bus = "cpu" })
  local tower = (gl and gl["slot" .. tostring(slot)]) or {}
  local payload = { bus = "cpu", slot = tonumber(slot) or 1, lock = false }
  for k, v in pairs(tower) do if payload[k] == nil then payload[k] = v end end
  local res, err = glc("modem", "set_cell_tower", payload)
  if not res then return { error = "GL unlock failed: " .. tostring(err) } end
  os.remove(STALE)
  append_event("user", "Cell lock cleared", "")
  return { ok = true }
end

-- WRITE: set band allowlists and/or the network mode, protected by
-- confirm-or-revert. args = { sa={..}, nsa={..}, lte={..}, mode="AUTO"|"NR5G"|"LTE" }
-- — each optional; any provided band list must be non-empty. Returns
-- { ok, window, applied={sa=..,nsa=..,lte=..,mode=..}, sub_id } or { error }.
function M.set_bands(args)
  -- Validate + collect the RATs being changed.
  local changes = {}
  for _, rat in ipairs(RATS) do
    local sel = args and args[rat.key]
    if type(sel) == "table" then
      if #sel == 0 then
        return { error = "refusing to write an empty " .. rat.key .. " list (would drop that RAT)" }
      end
      local parts = {}
      for _, b in ipairs(sel) do
        local n = tonumber(b)
        if not n or n < 1 or n ~= math.floor(n) then
          return { error = "invalid band value: " .. tostring(b) }
        end
        parts[#parts + 1] = tostring(n)
      end
      changes[#changes + 1] = { key = rat.key, param = rat.param, list = table.concat(parts, ":") }
    end
  end
  local mode = args and args.mode
  if mode ~= nil and not MODES[mode] then
    return { error = "invalid mode: " .. tostring(mode) }
  end
  if #changes == 0 and not mode then return { error = "no changes provided" } end

  if file_exists(PENDING) then
    return { error = "another change is pending; keep or revert it first" }
  end

  local sub_id, _, _, slot = resolve_active()

  -- Capture PREV (the revert target) and stash APPLIED for confirm()'s durable commit.
  local lines = { "SUB_ID=" .. sub_id, "SLOT=" .. tostring(slot) }
  for _, c in ipairs(changes) do
    local prev = pref_raw(at('AT+QNWPREFCFG="' .. c.param .. '"', sub_id), c.param)
    lines[#lines + 1] = "PREV_" .. c.param .. "=" .. prev
    lines[#lines + 1] = "APPLIED_" .. c.param .. "=" .. c.list
  end
  if mode then
    local mblob = at('AT+QNWPREFCFG="mode_pref"', sub_id)
    local pmode = (mblob and mblob:match('"mode_pref",([%w:]+)')) or ""
    lines[#lines + 1] = "PREV_mode_pref=" .. pmode
    lines[#lines + 1] = "APPLIED_mode_pref=" .. mode
  end

  os.execute("mkdir -p /etc/mudimodem 2>/dev/null")
  local f = io.open(PENDING, "w")
  if not f then return { error = "cannot write pending state" } end
  f:write(table.concat(lines, "\n") .. "\n")
  f:close()

  -- Arm the watchdog, and CONFIRM it is live before the writes. No net, no write.
  os.remove(ARMED)
  os.execute(REVERT_BIN .. " watch >/dev/null 2>&1 &")
  os.execute("sleep 1")
  if not file_exists(ARMED) then
    os.remove(PENDING)
    return { error = "revert watchdog failed to arm; no change written" }
  end

  -- Safe to write: a bad change now self-reverts within the window.
  local applied = {}
  for _, c in ipairs(changes) do
    at('AT+QNWPREFCFG="' .. c.param .. '",' .. c.list, sub_id)
    applied[c.key] = c.list
  end
  if mode then
    at('AT+QNWPREFCFG="mode_pref",' .. mode, sub_id)
    applied.mode = mode
  end

  -- Persist a "You applied bands" event for the Tracking timeline.
  local bits = {}
  if applied.sa  then bits[#bits + 1] = "SA "  .. applied.sa:gsub(":", " n"):gsub("^", "n") end
  if applied.nsa then bits[#bits + 1] = "NSA " .. applied.nsa:gsub(":", " n"):gsub("^", "n") end
  if applied.lte then bits[#bits + 1] = "LTE " .. applied.lte:gsub(":", " B"):gsub("^", "B") end
  if applied.mode then bits[#bits + 1] = "mode " .. applied.mode end
  append_event("user", "Bands applied", table.concat(bits, "; "))

  return { ok = true, window = 60, applied = applied, sub_id = sub_id }
end

-- READ: the recorded history (samples + user/dog events) for the Tracking page.
-- args = { since = <epoch ms> } — return only records newer than `since`, else
-- all (retained 24h). Files absent (collector not started) => empty arrays.
function M.get_history(args)
  local since = args and tonumber(args.since) or nil
  local function read_lines(path)
    local out = {}
    local fh = io.open(path, "r")
    if not fh then return out end
    for line in fh:lines() do
      if #line > 1 then
        local ok, obj = pcall(cjson.decode, line)   -- cjson.decode can't yield; pcall is safe here
        if ok and type(obj) == "table" and obj.t then
          if not since or obj.t > since then out[#out + 1] = obj end
        end
      end
    end
    fh:close()
    return out
  end
  return { samples = arr(read_lines(SAMPLES)), events = arr(read_lines(EVENTS)), now = os.time() * 1000 }
end

-- Commit a pending change durably (Path B). Two things happen here:
--   1. stop the watchdog (remove pending) so it won't revert; and
--   2. write the kept bands into GL's OWN stored config via
--      cellular.modem set_feature_config — because `cellular_manager`
--      re-applies its stored config on restart/reboot, overwriting our raw-AT
--      write. Committing to GL's config makes the change survive that
--      (reference §11). Our raw-AT write already made it live, so nothing
--      re-registers here.
function M.confirm(args)
  if pending_get("KIND") == "cell" then
    -- GL wrote its own store when the lock was applied; keeping it needs no
    -- Path-B commit — just stand the watchdog down.
    os.remove(PENDING)
    append_event("user", "Kept", "Cell lock confirmed")
    return { ok = true, confirmed = true, durable = true }
  end

  local slot = pending_get("SLOT")
  local durable = false

  if slot and slot ~= "nil" then
    local all = ucall("cellular.modem", "get_all_config", { bus = "cpu" })
    local sf = all and all.slot_feature
    if sf then
      local loc, cur
      for key, val in pairs(sf) do
        if key:match("^s" .. slot .. "_") then loc, cur = key, val end
      end
      if loc then
        local cb = (cur and cur.band) or {}
        local bl = cb.band_list or {}
        -- Start from GL's current band_list, then override each RAT we applied.
        local band_list = {
          LTE = arr(bl.LTE), ["NR-SA"] = arr(bl["NR-SA"]), ["NR-NSA"] = arr(bl["NR-NSA"]),
        }
        local any = false
        for _, rat in ipairs(RATS) do
          local ap = pending_get("APPLIED_" .. rat.param)
          if ap and ap ~= "" then
            local list = {}
            for n in ap:gmatch("(%d+)") do
              local v = tonumber(n); if v and v > 0 then list[#list + 1] = v end
            end
            band_list[rat.gl] = arr(list)
            any = true
          end
        end
        -- Mode: GL's network_mode == the mode_pref value (AUTO/NR5G/LTE).
        local nm = pending_get("APPLIED_mode_pref")
        if not nm or nm == "" then nm = (cur and cur.network_mode) or "AUTO" else any = true end
        if any then
          local data = {
            network_mode = nm,
            band = { band_enable = true, band_filter_mode = cb.band_filter_mode or 0, band_list = band_list },
          }
          local res = ucall("cellular.modem", "set_feature_config",
                            { bus = "cpu", location_id = loc, data = data })
          durable = (type(res) == "table" and res.ok == true) or false
        end
      end
    end
  end

  os.remove(PENDING)
  append_event("user", "Kept", "Change confirmed" .. (durable and " (durable)" or ""))
  return { ok = true, confirmed = true, durable = durable }
end

-- Revert a pending change NOW (don't wait out the window). Writes the previous
-- config back and clears pending, so the still-sleeping watchdog then finds
-- nothing to do. Same restore the watchdog would perform on timeout.
function M.revert_now(args)
  if not file_exists(PENDING) then return { ok = true, note = "nothing pending" } end

  if pending_get("KIND") == "cell" then
    local slot = tonumber(pending_get("SLOT")) or 1
    local sub  = tonumber(pending_get("SUB_ID")) or 1
    local rat  = pending_get("RAT") or "5g"

    -- GL-INDEPENDENT unlock FIRST (Finding C1): this is what actually frees
    -- the link. set_cell_tower can fail (GL error code 20002050, or a
    -- refusal while an operator lock exists) -- a manual revert must not
    -- leave the modem locked with the watchdog already torn down, which
    -- would defeat the whole safety guarantee. Mirrors what the watchdog's
    -- own cell-revert does (mudimodem-revert restore_from_pending).
    at('AT+QNWLOCK="common/' .. rat .. '",0', sub)
    local pm = pending_get("PREV_mode_pref")
    if pm and pm ~= "" then at('AT+QNWPREFCFG="mode_pref",' .. pm, sub) end
    local pd = pending_get("PREV_nr5g_disable_mode")
    if pd and pd ~= "" then at('AT+QNWPREFCFG="nr5g_disable_mode",' .. pd, sub) end
    local psc = pending_get("PREV_SAVE_CTRL")
    if psc and psc ~= "" then at('AT+QNWLOCK="save_ctrl",' .. psc, sub) end

    -- THEN reconcile GL's store, best-effort -- the link is already safe by
    -- this point regardless of whether this succeeds. If it fails, drop the
    -- STALE marker so the frontend offers a reconcile instead of silently
    -- disagreeing with the modem.
    local gl = glc("modem", "get_cell_tower", { bus = "cpu" })
    local tower = (gl and gl["slot" .. slot]) or {}
    local payload = { bus = "cpu", slot = slot, lock = false }
    for k, v in pairs(tower) do if payload[k] == nil then payload[k] = v end end
    local res = glc("modem", "set_cell_tower", payload)
    if not res then
      os.execute("mkdir -p /etc/mudimodem 2>/dev/null")
      local sf = io.open(STALE, "w")
      if sf then sf:close() end
    end

    os.remove(PENDING)
    os.remove(ARMED)
    append_event("user", "Reverted", "Cell lock removed")
    return { ok = true, reverted = true }
  end

  local sub = tonumber(pending_get("SUB_ID")) or 1
  local restored = {}
  for _, rat in ipairs(RATS) do
    local prev = pending_get("PREV_" .. rat.param)
    if prev and prev ~= "" then
      at('AT+QNWPREFCFG="' .. rat.param .. '",' .. prev, sub)
      restored[rat.key] = prev
    end
  end
  local pmode = pending_get("PREV_mode_pref")
  if pmode and pmode ~= "" then
    at('AT+QNWPREFCFG="mode_pref",' .. pmode, sub)
    restored.mode = pmode
  end
  os.remove(PENDING)
  os.remove(ARMED)
  append_event("user", "Reverted", "Restored previous bands")
  return { ok = true, reverted = true, restored = restored }
end

-- ============================ Phase 3: AT console ============================
-- Raw AT over OUR OWN channel (/dev/at_mdm0), NOT GL's modem.CPU.AT. The heavy
-- lifting — flock serialization, gl_modem SIGSTOP with paired SIGCONT +
-- startup recovery, drain/terminator read loop, timeout — lives in the Python
-- tool; this method only clamps args, spawns it, and parses the one-line
-- envelope (MM-AT:<status>:<elapsed_ms>). The port has NO sub_id: it answers
-- for the ACTIVE subscription only (spec 2026-07-18 §0).
--
-- io.popen blocks this nginx worker until the tool exits. The tool self-limits
-- to timeout + lock-wait, so the block is bounded (consistent with the
-- existing os.execute use in set_bands). No ubus in here, so no cosocket, so
-- this is safe even though it blocks.
local AT_TOOL = os.getenv("MUDIMODEM_AT_TOOL") or "/usr/lib/mudimodem/mudimodem-at.py"

function M.at_console(args)
  local cmd = args and args.cmd
  if type(cmd) ~= "string" then return { error = "cmd required" } end
  -- One command per send: collapse CR/LF, trim. Raw otherwise (it's a console).
  cmd = cmd:gsub("[\r\n]+", " "):match("^%s*(.-)%s*$")
  if cmd == "" then return { error = "cmd required" } end
  if #cmd > 256 then return { error = "command too long (max 256 chars)" } end
  local timeout = tonumber(args and args.timeout) or 8
  if timeout < 1 then timeout = 1 end
  if timeout > 60 then timeout = 60 end
  timeout = math.floor(timeout)

  -- POSIX shell single-quote escaping: ' -> '\''. AT_TOOL is operator config,
  -- not request input, so this isn't exploitable — quoted for consistency.
  local quoted = "'" .. cmd:gsub("'", "'\\''") .. "'"
  local quoted_tool = "'" .. AT_TOOL:gsub("'", "'\\''") .. "'"
  local f = io.popen("python3 " .. quoted_tool .. " --envelope --timeout " ..
                     timeout .. " " .. quoted .. " 2>/dev/null")
  if not f then return { error = "failed to spawn the AT tool" } end
  local out = f:read("*a") or ""
  f:close()

  local status, ms, rest = out:match("^MM%-AT:(%w+):(%d+)\r?\n?(.*)$")
  if not status then
    return { error = "AT tool returned no envelope (is " .. AT_TOOL .. " deployed?)" }
  end
  if status == "busy" then return { error = "channel busy - another command in flight" } end
  if status == "openfail" then return { error = "cannot open the AT port (/dev/at_mdm0)" } end
  if status == "ok" or status == "timeout" then
    return { ok = true, status = status, response = rest, elapsed_ms = tonumber(ms) }
  end
  return { error = "AT tool returned unexpected status: " .. status }
end

-- ============================ Speedtest ============================
-- On-demand (+ optional scheduled) download/upload/latency test. The test
-- itself is pure IP traffic run by tools/mudimodem-speedtest.py, spawned
-- DETACHED (like mudimodem-revert) because a fixed-size test takes ~10-20s --
-- too long for a single $rpcRequest. Results persist in /etc/mudimodem (NOT
-- /tmp, unlike the RF-history telemetry) so they survive a normal reboot.
local SPEEDTEST_BIN      = os.getenv("MUDIMODEM_SPEEDTEST_BIN")      or "/usr/lib/mudimodem/mudimodem-speedtest.py"
local SPEEDTEST_HIST     = os.getenv("MUDIMODEM_SPEEDTEST_HIST")     or "/etc/mudimodem/speedtests.jsonl"
local SPEEDTEST_STATUS   = os.getenv("MUDIMODEM_SPEEDTEST_STATUS")   or "/tmp/mudimodem/speedtest-status.json"
local SPEEDTEST_SCHEDULE = os.getenv("MUDIMODEM_ST_SCHEDULE")        or "/etc/mudimodem/speedtest-schedule.json"

-- Allowed schedule cadences (seconds) -- the UI's fixed dropdown (30m/1h/2h/
-- 6h/12h/24h); set_speedtest_schedule refuses anything else.
local SCHEDULE_SECONDS = { [1800] = true, [3600] = true, [7200] = true,
                           [21600] = true, [43200] = true, [86400] = true }

local function nullish(v) return v == nil or v == cjson.null end

-- Resolve an outbound interface ("cellular"|"wired") to its LIVE Linux device
-- via ubus network.interface dump -- NEVER hardcoded. This box's own eth0 is
-- bridged into LAN rather than acting as WAN, and the cellular device index
-- has been observed to change (rmnet_data0 <-> rmnet_data1) after a modem
-- reconnect, so resolving fresh every call is the only correct approach.
-- Returns { device = <string|nil>, up = <bool> }.
local function resolve_iface(which)
  local dump = ucall("network.interface", "dump", {})
  local ifaces = (dump and dump.interface) or {}
  local function pick(dev)
    if nullish(dev) then return nil end
    return dev
  end
  if which == "cellular" then
    for _, i in ipairs(ifaces) do
      local name = tostring(i.interface or "")
      if i.proto == "rmnet" and not name:match("_6$") then
        local dev = pick(i.l3_device) or pick(i.device)
        return { device = dev, up = (i.up == true) and dev ~= nil }
      end
    end
  elseif which == "wired" then
    for _, i in ipairs(ifaces) do
      if i.interface == "wan" then
        local dev = pick(i.l3_device) or pick(i.device)
        return { device = dev, up = (i.up == true) and dev ~= nil }
      end
    end
  end
  return { device = nil, up = false }
end

function M.get_speedtest_interfaces(args)
  return { cellular = resolve_iface("cellular"), wired = resolve_iface("wired") }
end

local function read_json_file(path, default)
  local f = io.open(path, "r")
  if not f then return default end
  local raw = f:read("*a")
  f:close()
  local ok, obj = pcall(cjson.decode, raw)   -- cjson.decode can't yield; pcall is safe here
  if not ok or type(obj) ~= "table" then return default end
  return obj
end

local function write_json_file(path, obj)
  local dir = path:match("(.*/)")
  if dir then os.execute("mkdir -p " .. dir .. " 2>/dev/null") end
  local f = io.open(path, "w")
  if not f then return false end
  f:write(cjson.encode(obj))
  f:close()
  return true
end

function M.run_speedtest(args)
  local iface = (args and args.iface) or "cellular"
  if iface ~= "cellular" and iface ~= "wired" then
    return { error = "iface must be 'cellular' or 'wired'" }
  end
  local info = resolve_iface(iface)
  if not info.up or not info.device then
    return { error = "iface_down", iface = iface }
  end

  local st = read_json_file(SPEEDTEST_STATUS, nil)
  if st and st.running then return { running = true } end

  os.execute("mkdir -p /etc/mudimodem /tmp/mudimodem 2>/dev/null")
  write_json_file(SPEEDTEST_STATUS, { running = true, phase = "starting", iface = iface })
  local quoted_bin = "'" .. SPEEDTEST_BIN:gsub("'", "'\\''") .. "'"
  os.execute("python3 " .. quoted_bin .. " --trigger manual --iface " .. iface .. " >/dev/null 2>&1 &")
  return { started = true }
end

function M.get_speedtest_status(args)
  return read_json_file(SPEEDTEST_STATUS, { running = false })
end

function M.get_speedtest_history(args)
  local since = args and tonumber(args.since) or nil
  local iface = args and args.iface or nil
  local limit = args and tonumber(args.limit) or nil
  local out = {}
  local fh = io.open(SPEEDTEST_HIST, "r")
  if fh then
    for line in fh:lines() do
      if #line > 1 then
        local ok, obj = pcall(cjson.decode, line)
        if ok and type(obj) == "table" and obj.t then
          if (not since or obj.t > since) and (not iface or obj.iface == iface) then
            out[#out + 1] = obj
          end
        end
      end
    end
    fh:close()
  end
  if limit and #out > limit then
    local trimmed = {}
    for i = #out - limit + 1, #out do trimmed[#trimmed + 1] = out[i] end
    out = trimmed
  end
  return { results = arr(out) }
end

function M.clear_speedtest_history(args)
  os.execute("mkdir -p /etc/mudimodem 2>/dev/null")
  local f = io.open(SPEEDTEST_HIST, "w")
  if f then f:close() end
  return { ok = true }
end

function M.get_speedtest_schedule(args)
  return read_json_file(SPEEDTEST_SCHEDULE, { enabled = false, interval_seconds = 21600, last_run = 0 })
end

function M.set_speedtest_schedule(args)
  local enabled = (args and args.enabled) and true or false
  local interval = tonumber(args and args.interval_seconds)
  if not interval or not SCHEDULE_SECONDS[interval] then
    return { error = "interval_seconds must be one of 1800/3600/7200/21600/43200/86400" }
  end
  local cur = M.get_speedtest_schedule({})
  os.execute("mkdir -p /etc/mudimodem 2>/dev/null")
  local f = io.open(SPEEDTEST_SCHEDULE, "w")
  if not f then return { error = "cannot write schedule config" } end
  f:write(cjson.encode({ enabled = enabled, interval_seconds = interval, last_run = cur.last_run or 0 }))
  f:close()
  return { ok = true, enabled = enabled, interval_seconds = interval }
end

return M
